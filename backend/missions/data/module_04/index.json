{
  "id": 4,
  "title": "Volumes & Storage",
  "theme": "Persisting data",
  "totalLevels": 6,
  "missions": [
    {
      "id": "module_04_level_01",
      "moduleId": 4,
      "levelId": 1,
      "title": "Named Volume Basics",
      "moduleTitle": "Volumes & Storage",
      "difficulty": "easy",
      "xp": 50,
      "story": "Containers are ephemeral — when they die, their data dies too. Named volumes live beyond containers. Create a volume named `app-data`.",
      "objectives": [
        "Create a Docker named volume called `app-data`"
      ],
      "hints": [
        "`docker volume create <name>` creates a named volume",
        "`docker volume create app-data`",
        "`docker volume create app-data`"
      ],
      "validation": [
        {
          "type": "volume_exists",
          "params": {
            "name": "app-data"
          },
          "description": "name=app-data"
        }
      ],
      "initialState": {
        "summary": "Clean Docker environment",
        "workspaceFiles": []
      }
    },
    {
      "id": "module_04_level_02",
      "moduleId": 4,
      "levelId": 2,
      "title": "Mount a Volume",
      "moduleTitle": "Volumes & Storage",
      "difficulty": "easy",
      "xp": 50,
      "story": "A volume is only useful when mounted. Run an `alpine` container named `writer` with volume `app-data` mounted at `/data`, then write a file to it.",
      "objectives": [
        "Run container `writer` from `alpine` with `app-data` mounted at `/data` (detached, `sleep 3600`)",
        "Create file `/data/record.txt` inside the container with content `mission=complete`"
      ],
      "hints": [
        "Use `-v <volume>:<path>` or `--mount` to attach a volume",
        "`docker run -d --name writer -v app-data:/data alpine sleep 3600`",
        "Then `docker exec writer sh -c 'echo mission=complete > /data/record.txt'`"
      ],
      "validation": [
        {
          "type": "volume_mounted",
          "params": {
            "container": "writer",
            "volume": "app-data",
            "path": "/data"
          },
          "description": "container=writer, volume=app-data, path=/data"
        },
        {
          "type": "file_in_container",
          "params": {
            "container": "writer",
            "path": "/data/record.txt"
          },
          "description": "container=writer, path=/data/record.txt"
        }
      ],
      "initialState": {
        "summary": "Volume `app-data` pre-created",
        "workspaceFiles": []
      }
    },
    {
      "id": "module_04_level_03",
      "moduleId": 4,
      "levelId": 3,
      "title": "Data Survives Container Death",
      "moduleTitle": "Volumes & Storage",
      "difficulty": "medium",
      "xp": 100,
      "story": "Prove that data in a volume outlives its container. The `writer` container has been removed. Run a new container `reader` on the same volume and confirm the file still exists.",
      "objectives": [
        "Run container `reader` from `alpine` mounting `app-data` at `/data`",
        "Read `/data/record.txt` and confirm content is `mission=complete`"
      ],
      "hints": [
        "Mount the same volume in a new container",
        "`docker run -d --name reader -v app-data:/data alpine sleep 3600`",
        "`docker exec reader cat /data/record.txt` should show `mission=complete`"
      ],
      "validation": [
        {
          "type": "volume_mounted",
          "params": {
            "container": "reader",
            "volume": "app-data",
            "path": "/data"
          },
          "description": "container=reader, volume=app-data, path=/data"
        },
        {
          "type": "file_content",
          "params": {
            "container": "reader",
            "path": "/data/record.txt",
            "contains": "mission=complete"
          },
          "description": "container=reader, path=/data/record.txt, contains=mission=complete"
        }
      ],
      "initialState": {
        "summary": "- Volume `app-data` exists with `/data/record.txt` containing `mission=complete` - Container `writer` has been removed",
        "workspaceFiles": []
      }
    },
    {
      "id": "module_04_level_04",
      "moduleId": 4,
      "levelId": 4,
      "title": "Bind Mounts",
      "moduleTitle": "Volumes & Storage",
      "difficulty": "medium",
      "xp": 100,
      "story": "Bind mounts link a host directory directly into a container — perfect for development. Mount the host directory `/workspace/html` into an nginx container at `/usr/share/nginx/html`.",
      "objectives": [
        "Run `nginx` container named `dev-web` with host path `/workspace/html` bind-mounted at `/usr/share/nginx/html`, publishing port 8080"
      ],
      "hints": [
        "Use `-v /host/path:/container/path` for bind mounts",
        "Bind mounts use absolute host paths",
        "`docker run -d --name dev-web -v /workspace/html:/usr/share/nginx/html -p 8080:80 nginx`"
      ],
      "validation": [
        {
          "type": "container_running",
          "params": {
            "name": "dev-web"
          },
          "description": "name=dev-web"
        },
        {
          "type": "bind_mount",
          "params": {
            "container": "dev-web",
            "host_path": "/workspace/html",
            "container_path": "/usr/share/nginx/html"
          },
          "description": "container=dev-web, host_path=/workspace/html, container_path=/usr/share/nginx/html"
        },
        {
          "type": "http_responds",
          "params": {
            "url": "http://localhost:8080",
            "body_contains": "DockerMissions"
          },
          "description": "url=http://localhost:8080, body_contains=DockerMissions"
        }
      ],
      "initialState": {
        "summary": "`/workspace/html/index.html` pre-created with `<h1>DockerMissions</h1>`",
        "workspaceFiles": [
          {
            "path": "html/index.html",
            "content": "<h1>DockerMissions</h1>\n"
          }
        ]
      }
    },
    {
      "id": "module_04_level_05",
      "moduleId": 4,
      "levelId": 5,
      "title": "tmpfs Mount",
      "moduleTitle": "Volumes & Storage",
      "difficulty": "medium",
      "xp": 100,
      "story": "Some sensitive data (tokens, secrets) should never touch disk. Use a `tmpfs` mount for in-memory-only storage.",
      "objectives": [
        "Run container `secure-app` from `alpine` with a `tmpfs` mount at `/secrets` (detached, `sleep 3600`)",
        "Write a file `/secrets/token.txt` to it",
        "Confirm the data is in memory (not on a volume or bind mount)"
      ],
      "hints": [
        "`--tmpfs <path>` mounts an in-memory filesystem",
        "Data in tmpfs is lost when the container stops",
        "`docker run -d --name secure-app --tmpfs /secrets alpine sleep 3600`"
      ],
      "validation": [
        {
          "type": "container_running",
          "params": {
            "name": "secure-app"
          },
          "description": "name=secure-app"
        },
        {
          "type": "tmpfs_mounted",
          "params": {
            "container": "secure-app",
            "path": "/secrets"
          },
          "description": "container=secure-app, path=/secrets"
        },
        {
          "type": "file_in_container",
          "params": {
            "container": "secure-app",
            "path": "/secrets/token.txt"
          },
          "description": "container=secure-app, path=/secrets/token.txt"
        }
      ],
      "initialState": {
        "summary": "Clean Docker environment",
        "workspaceFiles": []
      }
    },
    {
      "id": "module_04_level_06",
      "moduleId": 4,
      "levelId": 6,
      "title": "Volume Backup",
      "moduleTitle": "Volumes & Storage",
      "difficulty": "hard",
      "xp": 200,
      "story": "Volumes must be backed up. Use a temporary container to tar the contents of `app-data` volume to `/backup/app-data.tar.gz` on the host.",
      "objectives": [
        "Run a temporary container that mounts `app-data` at `/data` and `/backup` as a bind mount",
        "Compress `/data` contents into `/backup/app-data.tar.gz`",
        "Container should stop after completing the backup"
      ],
      "hints": [
        "Use `docker run --rm` for throwaway containers",
        "Mount both the volume and the backup directory",
        "`docker run --rm -v app-data:/data -v /backup:/backup alpine tar czf /backup/app-data.tar.gz -C /data .`"
      ],
      "validation": [
        {
          "type": "file_exists_on_host",
          "params": {
            "path": "/backup/app-data.tar.gz"
          },
          "description": "path=/backup/app-data.tar.gz"
        },
        {
          "type": "tar_valid",
          "params": {
            "path": "/backup/app-data.tar.gz"
          },
          "description": "path=/backup/app-data.tar.gz"
        }
      ],
      "initialState": {
        "summary": "- Volume `app-data` with files pre-created - Host directory `/backup` exists and is writable",
        "workspaceFiles": []
      }
    }
  ]
}