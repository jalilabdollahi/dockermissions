      "type": "port_exposed",
      "params": {
        "service": "web",
        "host_port": 8080,
        "container_port": 80
      },
      "description": "service=web, host_port=8080, container_port=80"
    },
    {
      "type": "http_responds",
      "params": {
        "url": "http://localhost:8080",
        "status": 200
      },
      "description": "url=http://localhost:8080, status=200"
    }
  ],
