  "story": "Expose the nginx service on host port 8080.",
  "objectives": [
    "Add `ports: [\"8080:80\"]` to the `web` service",
    "Restart the stack",
    "Confirm http://localhost:8080 responds"
  ],
  "hints": [
    "Use `ports:` key under the service",
    "Format: `\"host:container\"`",
    "`ports: [\"8080:80\"]`"
